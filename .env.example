# Copy this file to .env and fill in your Supabase credentials.
# Get them at: https://supabase.com/dashboard/project/_/settings/api
#
# Without these set, the app works in local/guest mode (all data stays on device).
# With them set, you get Google OAuth, Apple Sign In, Email auth, and Phone OTP.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here
